<?xml version="1.0" encoding="UTF-8"?>
<!--
  A09 — Security Logging. Zwei Appender:
   - STDOUT: allgemeines Anwendungs-Log (von Docker eingesammelt).
   - AUDIT:  dedizierter, strukturierter Strom für sicherheitsrelevante
             Ereignisse (Logger-Name SECURITY_AUDIT). Es werden bewusst KEINE
             Passwörter, CAPTCHAs oder Tokens geloggt — siehe AuthEventListener.
-->
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Sicherheits-Audit als JSON-ähnliche Zeile (gut für Logstash/Loki). -->
    <appender name="AUDIT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","logger":"SECURITY_AUDIT","event":"%msg"}%n</pattern>
        </encoder>
    </appender>

    <logger name="SECURITY_AUDIT" level="INFO" additivity="false">
        <appender-ref ref="AUDIT"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
